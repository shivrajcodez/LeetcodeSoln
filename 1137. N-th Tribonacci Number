class Solution {
    public int tribonacci(int n) {
        // Handle base cases for n = 0, 1, 2
        if (n == 0) return 0;
        if (n == 1 || n == 2) return 1;

        // Initialize the first three numbers
        int t0 = 0, t1 = 1, t2 = 1;
        
        // Starting from i = 3, calculate up to n
        for (int i = 3; i <= n; i++) {
            int next = t0 + t1 + t2;
            // Shift the window forward
            t0 = t1;
            t1 = t2;
            t2 = next;
        }

        return t2;
    }
}
