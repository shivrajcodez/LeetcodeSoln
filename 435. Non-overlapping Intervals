import java.util.Arrays;
import java.util.Comparator;

class Solution {
    public int eraseOverlapIntervals(int[][] intervals) {
        if (intervals.length == 0) return 0;

        // Step 1: Sort intervals by their end times
        Arrays.sort(intervals, (a, b) -> Integer.compare(a[1], b[1]));

        int nonOverlappingCount = 1;
        int end = intervals[0][1];

        // Step 2: Iterate and pick intervals that finish earliest
        for (int i = 1; i < intervals.length; i++) {
            // If the start of the current interval is >= end of previous
            if (intervals[i][0] >= end) {
                nonOverlappingCount++;
                end = intervals[i][1];
            }
        }

        // Step 3: Result is total minus non-overlapping
        return intervals.length - nonOverlappingCount;
    }
}
