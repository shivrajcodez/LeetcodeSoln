/**
 * Definition for singly-linked list.
 * public class ListNode {
 * int val;
 * ListNode next;
 * ListNode() {}
 * ListNode(int val) { this.val = val; }
 * ListNode(int val, ListNode next) { this.val = val; this.next = next; }
 * }
 */
class Solution {
    public ListNode rotateRight(ListNode head, int k) {
        // Base cases: empty list, single node, or no rotation needed
        if (head == null || head.next == null || k == 0) {
            return head;
        }
        
        // 1. Compute the length of the list and locate the tail node
        int length = 1;
        ListNode tail = head;
        while (tail.next != null) {
            tail = tail.next;
            length++;
        }
        
        // 2. Normalize k to handle rotations larger than the list length
        k = k % length;
        if (k == 0) {
            return head; // No actual rotation needed
        }
        
        // 3. Connect the tail to the head to form a cycle
        tail.next = head;
        
        // 4. Find the new tail position: (length - k) steps from the head
        // Since we are already at the old tail, moving (length - k) steps 
        // puts us exactly at the new tail node.
        int stepsToNewTail = length - k;
        ListNode newTail = tail;
        for (int i = 0; i < stepsToNewTail; i++) {
            newTail = newTail.next;
        }
        
        // 5. The new head is right after the new tail
        ListNode newHead = newTail.next;
        
        // 6. Break the cycle
        newTail.next = null;
        
        return newHead;
    }
}
