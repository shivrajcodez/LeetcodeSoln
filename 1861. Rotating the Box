class Solution {
    public char[][] rotateTheBox(char[][] box) {
        int m = box.length;
        int n = box[0].length;

        // Step 1: Apply gravity to each row individually
        for (int i = 0; i < m; i++) {
            // 'empty' tracks the lowest available index where a stone can fall (rightmost)
            int empty = n - 1; 
            
            for (int j = n - 1; j >= 0; j--) {
                if (box[i][j] == '*') {
                    // Obstacle blocks further falling; reset empty pointer to just before it
                    empty = j - 1;
                } else if (box[i][j] == '#') {
                    // Move stone to the empty position
                    box[i][j] = '.';
                    box[i][empty] = '#';
                    // The next stone must land one position to the left
                    empty--;
                }
            }
        }

        // Step 2: Rotate the box 90 degrees clockwise
        // A matrix of size (m x n) becomes (n x m)
        char[][] rotatedBox = new char[n][m];
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                rotatedBox[j][m - 1 - i] = box[i][j];
            }
        }

        return rotatedBox;
    }
}
