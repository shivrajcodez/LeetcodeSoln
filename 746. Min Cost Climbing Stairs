class Solution {
    public int minCostClimbingStairs(int[] cost) {
        int n = cost.length;
        
        // We only need the costs to reach the previous two steps
        int prev1 = 0; // Represents min cost to reach step i-1
        int prev2 = 0; // Represents min cost to reach step i-2
        
        // Start from i = 2 because we can start at index 0 or 1 for free
        for (int i = 2; i <= n; i++) {
            // The cost to reach current step 'i' is:
            // Min(cost to reach i-1 + cost[i-1], cost to reach i-2 + cost[i-2])
            int current = Math.min(prev1 + cost[i - 1], prev2 + cost[i - 2]);
            
            // Shift values for the next iteration
            prev2 = prev1;
            prev1 = current;
        }
        
        return prev1;
    }
}
