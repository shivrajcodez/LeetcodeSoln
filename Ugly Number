class Solution {
    public boolean isUgly(int n) {
        // Ugly numbers must be positive
        if (n <= 0) return false;
        
        // Factors to check
        int[] factors = {2, 3, 5};
        
        for (int factor : factors) {
            // Keep dividing n by the factor as long as it is divisible
            while (n % factor == 0) {
                n /= factor;
            }
        }
        
        // If n is reduced to 1, it only had 2, 3, or 5 as prime factors
        return n == 1;
    }
}
