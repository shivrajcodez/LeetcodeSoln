class Solution {
    public int numTilings(int n) {
        if (n <= 2) return n;
        if (n == 3) return 5;
        
        long MOD = 1_000_000_007;
        
        // We only need to keep track of the last three states
        long t1 = 1; // T(n-3) -> for n=4, this is T(1)
        long t2 = 2; // T(n-2) -> for n=4, this is T(2)
        long t3 = 5; // T(n-1) -> for n=4, this is T(3)
        
        for (int i = 4; i <= n; i++) {
            long current = (2 * t3 + t1) % MOD;
            
            // Shift the window
            t1 = t2;
            t2 = t3;
            t3 = current;
        }
        
        return (int) t3;
    }
}
