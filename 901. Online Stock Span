import java.util.Stack;

class StockSpanner {
    // Stack stores int array: [price, span]
    private Stack<int[]> stack;

    public StockSpanner() {
        stack = new Stack<>();
    }
    
    public int next(int price) {
        int currentSpan = 1;
        
        // While stack has prices less than or equal to current price
        while (!stack.isEmpty() && stack.peek()[0] <= price) {
            // Add the span of the popped price to the current span
            currentSpan += stack.pop()[1];
        }
        
        // Push the current price and its calculated span
        stack.push(new int[]{price, currentSpan});
        
        return currentSpan;
    }
}
