import java.util.*;

class Solution {
    public int nearestExit(char[][] maze, int[] entrance) {
        int rows = maze.length;
        int cols = maze[0].length;
        
        // Direction vectors: up, down, left, right
        int[][] directions = {{-1, 0}, {1, 0}, {0, -1}, {0, 1}};
        
        // Queue for BFS: {row, col, steps}
        Queue<int[]> queue = new LinkedList<>();
        queue.offer(new int[]{entrance[0], entrance[1], 0});
        
        // Mark the entrance as visited
        maze[entrance[0]][entrance[1]] = '+';
        
        while (!queue.isEmpty()) {
            int[] current = queue.poll();
            int currRow = current[0];
            int currCol = current[1];
            int steps = current[2];
            
            for (int[] dir : directions) {
                int nextRow = currRow + dir[0];
                int nextCol = currCol + dir[1];
                
                // Check if the next cell is within bounds and is an empty path
                if (nextRow >= 0 && nextRow < rows && nextCol >= 0 && nextCol < cols 
                    && maze[nextRow][nextCol] == '.') {
                    
                    // Check if this empty cell is on the border (an exit)
                    if (nextRow == 0 || nextRow == rows - 1 || nextCol == 0 || nextCol == cols - 1) {
                        return steps + 1;
                    }
                    
                    // If not an exit, mark as visited and add to queue
                    maze[nextRow][nextCol] = '+';
                    queue.offer(new int[]{nextRow, nextCol, steps + 1});
                }
            }
        }
        
        // No exit found
        return -1;
    }
}
