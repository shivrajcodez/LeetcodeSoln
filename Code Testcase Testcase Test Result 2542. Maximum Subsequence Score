import java.util.Arrays;
import java.util.PriorityQueue;

class Solution {
    public long maxScore(int[] nums1, int[] nums2, int k) {
        int n = nums1.length;
        int[][] pairs = new int[n][2];
        
        for (int i = 0; i < n; i++) {
            pairs[i][0] = nums1[i];
            pairs[i][1] = nums2[i];
        }
        
        // Sort pairs by nums2 in descending order
        Arrays.sort(pairs, (a, b) -> b[1] - a[1]);
        
        // Min-heap to keep track of the largest k elements from nums1
        PriorityQueue<Integer> minHeap = new PriorityQueue<>(k);
        long currentSum = 0;
        long maxScore = 0;
        
        for (int i = 0; i < n; i++) {
            currentSum += pairs[i][0];
            minHeap.add(pairs[i][0]);
            
            // If we have more than k elements, remove the smallest one
            if (minHeap.size() > k) {
                currentSum -= minHeap.poll();
            }
            
            // If we have exactly k elements, calculate potential score
            // pairs[i][1] is the minimum in our subsequence because we sorted descending
            if (minHeap.size() == k) {
                maxScore = Math.max(maxScore, currentSum * pairs[i][1]);
            }
        }
        
        return maxScore;
    }
}
